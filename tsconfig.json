{
  "compilerOptions": {
    /* Cấu hình để dùng được đường dẫn src/ */
    "baseUrl": "./",
    "paths": {
      "src/*": ["src/*"]
    },

    /* Các thiết lập Module */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "lib": ["es2023"],
    
    /* Cấu hình NestJS và Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    
    /* Khả năng tương thích và Kiểm soát lỗi */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true, // Tránh lỗi chữ hoa/thường trên Vercel
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    
    /* Cấu hình Output */
    "outDir": "./dist",
    "sourceMap": true,
    "removeComments": true,
    "declaration": true,
    "incremental": true,
    "isolatedModules": true,
    "resolvePackageJsonExports": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}